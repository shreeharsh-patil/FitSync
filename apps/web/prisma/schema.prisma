generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  USER
  TRAINER
  ADMIN
  SUPER_ADMIN
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ExerciseCategory {
  STRENGTH
  CARDIO
  FLEXIBILITY
  BALANCE
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id              String    @id @default(uuid())
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  passwordHash    String?
  name            String?
  username        String?    @unique
  avatarUrl       String?
  role            Role      @default(USER)
  height          Float?
  weight          Float?
  fitnessGoal     String?
  activityLevel   String?
  dateOfBirth     DateTime?
  bio             String?
  isPublic        Boolean   @default(true)
  notificationPreferences String?  @default("{\"workouts\":true,\"hydration\":true,\"community\":false,\"aiDeloads\":true}")
  stripeCustomerId String?
  twoFactorSecret String?
  twoFactorEnabled   Boolean  @default(false)
  twoFactorBackupCodes String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]

  workouts        Workout[]
  workoutLogs     WorkoutLog[]
  workoutSchedules WorkoutSchedule[]
  nutritionLogs   NutritionLog[]
  progressEntries ProgressEntry[]
  posts           Post[]
  comments        Comment[]
  blogPosts       BlogPost[]
  notifications   Notification[]
  achievements    Achievement[]
  subscriptions   Subscription[]
  challenges      ChallengeParticipant[]
  sentMessages    Message[] @relation("sentMessages")
  receivedMessages Message[] @relation("receivedMessages")

  followers       Follows[] @relation("following")
  following       Follows[] @relation("follower")

  trainerProfile  TrainerProfile?
  bookings        Booking[]
  testimonials    Testimonial[]

  trainerFollows  TrainerFollow[]
  recipes         Recipe[]
  mealPlans       MealPlan[]
  macroTargets    MacroTarget[]

  trainerSessions  CoachingSession[] @relation("TrainerSessions")
  clientSessions   CoachingSession[] @relation("ClientSessions")
  orgMemberships   OrgMember[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Follows {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower    User @relation("follower", fields: [followerId], references: [id])
  following   User @relation("following", fields: [followingId], references: [id])

  @@id([followerId, followingId])
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender     User     @relation("sentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("receivedMessages", fields: [receiverId], references: [id])
}

model Workout {
  id          String     @id @default(uuid())
  userId      String
  name        String
  description String?
  difficulty  Difficulty
  daysPerWeek Int
  isPublic    Boolean    @default(false)
  isTemplate  Boolean    @default(false)
  tags        String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user        User            @relation(fields: [userId], references: [id])
  workoutLogs WorkoutLog[]
  exercises   WorkoutExercise[]
  schedules   WorkoutSchedule[]
}

model WorkoutExercise {
  id         String   @id @default(uuid())
  workoutId  String
  exerciseId String
  sets       Int
  reps       String
  restSec    Int
  order      Int
  createdAt  DateTime @default(now())

  workout    Workout  @relation(fields: [workoutId], references: [id])
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
}

model WorkoutSchedule {
  id        String   @id @default(uuid())
  userId    String
  workoutId String
  date      DateTime
  completed Boolean  @default(false)
  createdAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  workout  Workout  @relation(fields: [workoutId], references: [id])

  @@unique([userId, workoutId, date])
}

model WorkoutLog {
  id             String   @id @default(uuid())
  userId         String
  workoutId      String?
  logDate        DateTime
  startTime      DateTime
  endTime        DateTime?
  durationMins   Int?
  caloriesBurned Int?
  notes          String?
  exercises      String   // JSON: Array of {exerciseId, sets[{reps,weight,restSec}]}
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id])
  workout        Workout? @relation(fields: [workoutId], references: [id])
}

model Exercise {
  id              String           @id @default(uuid())
  name            String           @unique
  category        ExerciseCategory
  muscleGroups    String
  equipment       String
  instructions    String
  videoUrl        String?
  gifUrl          String?
  difficulty      Difficulty
  isCustom        Boolean          @default(false)
  createdBy       String?
  createdAt       DateTime         @default(now())
  workoutExercises WorkoutExercise[]
}

model NutritionLog {
  id            String   @id @default(uuid())
  userId        String
  logDate       DateTime
  mealType      MealType
  foodItems     String   // JSON: Array of {foodId, name, qty, unit, calories, protein, carbs, fat}
  totalCalories Float
  waterMl       Int      @default(0)
  notes         String?
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])
}

model ProgressEntry {
  id           String   @id @default(uuid())
  userId       String
  logDate      DateTime
  weight       Float?
  bodyFatPct   Float?
  measurements String?  // JSON: {chest, waist, hips, arms, thighs, calves, shoulders}
  photoUrl     String?
  notes        String?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id         String   @id @default(uuid())
  userId     String
  type       String   // "target_weight" | "target_body_fat" | "target_measurement_chest" etc.
  target     Float
  targetDate DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id              String     @id @default(uuid())
  authorId        String
  title           String
  slug            String     @unique
  excerpt         String
  content         String
  featuredImageUrl String?
  category        String
  tags            String?
  metaTitle       String?
  metaDescription String?
  status          PostStatus @default(DRAFT)
  publishedAt     DateTime?
  viewCount       Int        @default(0)
  readingTimeMins Int?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  author          User       @relation(fields: [authorId], references: [id])
}

model Post {
  id            String    @id @default(uuid())
  userId        String
  content       String
  mediaUrls     String?
  likesCount    Int       @default(0)
  commentsCount Int       @default(0)
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id])
  comments      Comment[]
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  parentId  String?
  content   String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  parent    Comment? @relation("CommentToComment", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentToComment")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  data      String   // JSON
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model Challenge {
  id               String   @id @default(uuid())
  title            String
  startDate        DateTime
  endDate          DateTime
  rules            String   // JSON
  participantCount Int      @default(0)
  createdAt        DateTime @default(now())

  participants     ChallengeParticipant[]
}

model ChallengeParticipant {
  challengeId String
  userId      String
  progress    String   // JSON
  rank        Int?
  joinedAt    DateTime @default(now())

  challenge   Challenge @relation(fields: [challengeId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@id([challengeId, userId])
}

model Achievement {
  id        String   @id @default(uuid())
  userId    String
  badgeType String
  earnedAt  DateTime @default(now())
  metadata  String?  // JSON
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model MealPlan {
  id            String    @id @default(uuid())
  userId        String
  name          String
  goal          String
  calories      Int
  preferences   String    // JSON array
  allergies     String    // JSON array
  dietType      String
  days          MealPlanDay[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id])
}

model MealPlanDay {
  id            String    @id @default(uuid())
  mealPlanId    String
  dayOfWeek     Int
  meals         String   // JSON: array of {mealType, name, calories, protein, carbs, fat, ingredients}
  totalCalories Int

  mealPlan      MealPlan  @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
}

model Subscription {
  id               String   @id @default(uuid())
  userId           String
  plan             String
  status           String
  stripeSubId      String?
  currentPeriodEnd DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id])
}

model Recipe {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  ingredients String   // JSON array
  instructions String?
  prepTime    Int?
  cookTime    Int?
  servings    Int      @default(1)
  calories    Float    @default(0)
  protein     Float    @default(0)
  carbs       Float    @default(0)
  fat         Float    @default(0)
  imageUrl    String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model MacroTarget {
  id        String   @id @default(uuid())
  userId    String
  dayOfWeek Int?     // 0-6 for Sunday-Saturday, null = default
  calories  Float    @default(2400)
  protein   Float    @default(180)
  carbs     Float    @default(280)
  fat       Float    @default(80)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, dayOfWeek])
  @@index([userId])
}

model TrainerProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  specialties     String   // JSON array
  certifications  String   // JSON array
  bio             String?
  experience      Int?
  hourlyRate      Float?
  isAvailable     Boolean  @default(true)
  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])
  packages        TrainingPackage[]
  testimonials    Testimonial[]
  timeSlots       TimeSlot[]
  followers       TrainerFollow[]
}

model TrainingPackage {
  id            String   @id @default(uuid())
  trainerId     String
  name          String
  description   String?
  sessions      Int
  price         Float
  durationWeeks Int
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  trainer       TrainerProfile @relation(fields: [trainerId], references: [id])
  bookings      Booking[]
}

model TimeSlot {
  id        String   @id @default(uuid())
  trainerId String
  dayOfWeek Int
  startTime String
  endTime   String
  isBooked  Boolean  @default(false)

  trainer   TrainerProfile @relation(fields: [trainerId], references: [id])
}

model Booking {
  id        String   @id @default(uuid())
  userId    String
  packageId String
  dateTime  DateTime
  status    String   @default("PENDING")
  notes     String?
  createdAt DateTime @default(now())

  user      User           @relation(fields: [userId], references: [id])
  package   TrainingPackage @relation(fields: [packageId], references: [id])
}

model Testimonial {
  id        String   @id @default(uuid())
  trainerId String
  userId    String
  content   String
  rating    Int
  createdAt DateTime @default(now())

  trainer   TrainerProfile @relation(fields: [trainerId], references: [id])
  user      User           @relation(fields: [userId], references: [id])
}

model TrainerFollow {
  id        String   @id @default(uuid())
  userId    String
  trainerId String
  createdAt DateTime @default(now())

  user      User           @relation(fields: [userId], references: [id])
  trainer   TrainerProfile @relation(fields: [trainerId], references: [id])

  @@unique([userId, trainerId])
}

model CoachingSession {
  id          String   @id @default(uuid())
  trainerId   String
  clientId    String
  startTime   DateTime
  endTime     DateTime?
  status      String   // SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED
  sessionType String   // ONE_ON_ONE, GROUP
  notes       String?
  rating      Int?
  feedback    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  trainer     User     @relation("TrainerSessions", fields: [trainerId], references: [id])
  client      User     @relation("ClientSessions", fields: [clientId], references: [id])
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  industry  String?
  size      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  teams     Team[]
  members   OrgMember[]
}

model Team {
  id           String   @id @default(uuid())
  orgId        String
  name         String
  description  String?
  createdAt    DateTime @default(now())
  organization Organization @relation(fields: [orgId], references: [id])
  members      OrgMember[]
}

model OrgMember {
  id       String   @id @default(uuid())
  orgId    String
  teamId   String?
  userId   String
  role     String   // ADMIN, MANAGER, MEMBER
  joinedAt DateTime @default(now())
  organization Organization @relation(fields: [orgId], references: [id])
  team         Team?    @relation(fields: [teamId], references: [id])
  user         User     @relation(fields: [userId], references: [id])

  @@unique([orgId, userId])
}

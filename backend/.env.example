# ─── Server ───
PORT=5000
NODE_ENV=development

# ─── MongoDB ───
# Get your free cluster at https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/fitsync?retryWrites=true&w=majority

# ─── JWT (generate a random 64-char secret) ───
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ─── CORS (frontend URL) ───
FRONTEND_URL=http://localhost:3000

# ─── NextAuth (used by frontend for session) ───
NEXTAUTH_SECRET=your-nextauth-secret-change-this-in-production
NEXTAUTH_URL=http://localhost:3000

# ─── OAuth Providers (optional) ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
